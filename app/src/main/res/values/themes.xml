<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AppKasir" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/pos_black</item>
        <item name="colorPrimaryVariant">@color/pos_gray_900</item>
        <item name="colorSecondary">@color/pos_gray_600</item>
        <item name="colorSecondaryVariant">@color/pos_gray_700</item>
        <item name="colorTertiary">@color/pos_gray_500</item>
        <item name="android:windowBackground">@drawable/bg_app_modern</item>
        <item name="android:colorBackground">@color/pos_background</item>
        <item name="colorSurface">@color/pos_surface</item>
        <item name="colorSurfaceVariant">@color/pos_surface_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnBackground">@color/pos_text_primary</item>
        <item name="colorOnSurface">@color/pos_text_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/pos_gray_900</item>
        <item name="android:navigationBarColor">@color/pos_surface</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="materialButtonStyle">@style/ModernButton</item>
        <item name="materialCardViewStyle">@style/ModernCardView</item>
        <item name="materialAlertDialogTheme">@style/AlertDialogStyle</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationStyle</item>
    </style>

    <style name="ModernButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">6dp</item>
        <item name="backgroundTint">@color/pos_gray_800</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="rippleColor">@color/pos_gray_400</item>
    </style>

    <style name="ModernCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/pos_border_light</item>
        <item name="cardBackgroundColor">@color/pos_surface</item>
        <item name="android:layout_margin">6dp</item>
    </style>

    <style name="MlPresetButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/pos_surface</item>
        <item name="strokeColor">@color/pos_border_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">999dp</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="SectionHeaderText">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_text_secondary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="SubtitleText">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/pos_text_tertiary</item>
    </style>

    <style name="ButtonGoldStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pos_gray_800</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">8dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="rippleColor">@color/pos_gray_400</item>
    </style>

    <style name="ButtonBlueStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/pos_gray_600</item>
        <item name="android:textColor">@color/pos_gray_800</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeWidth">2dp</item>
        <item name="backgroundTint">@color/pos_surface</item>
        <item name="rippleColor">@color/pos_gray_200</item>
    </style>

    <style name="ButtonRedStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pos_error</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="TitleLargeStyle">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_gray_900</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <style name="TitleMediumStyle">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="android:letterSpacing">0.005</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BodyLargeStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="BodyMediumStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/pos_text_secondary</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="CurrencyTextStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_success</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="AlertDialogStyle" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/DialogBody</item>
        <item name="buttonBarPositiveButtonStyle">@style/ButtonGoldStyle</item>
        <item name="android:background">@color/pos_surface</item>
    </style>

    <style name="DialogTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_gray_900</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="DialogBody">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/pos_text_secondary</item>
        <item name="android:lineHeight">22sp</item>
    </style>

    <style name="DynamicCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">10dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/pos_gray_200</item>
        <item name="cardBackgroundColor">@color/pos_surface</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/pos_surface</item>
        <item name="chipStrokeColor">@color/pos_border_light</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="checkedIconTint">@color/pos_gray_800</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Window Animation Style for Modern Transitions -->
    <style name="WindowAnimationStyle" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in_up</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_in_down</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_in_right</item>
    </style>

    <!-- Modern Input Field Style -->
    <style name="ModernInputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/pos_gray_400</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="hintTextColor">@color/pos_text_tertiary</item>
        <item name="android:textColorHint">@color/pos_text_hint</item>
    </style>

    <!-- Elevated Button Style -->
    <style name="ElevatedButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">8dp</item>
        <item name="backgroundTint">@color/pos_gray_800</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

</resources>
