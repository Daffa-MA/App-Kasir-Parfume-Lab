<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AppKasir" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors (Material Design 3) -->
        <item name="colorPrimary">@color/pos_gold</item>
        <item name="colorPrimaryVariant">@color/pos_gold_light</item>
        <item name="colorSecondary">@color/pos_gold</item>
        <item name="colorSecondaryVariant">@color/pos_gold</item>
        <item name="colorTertiary">@color/pos_gold_light</item>
        
        <!-- Background & Surface -->
        <item name="android:windowBackground">@drawable/bg_app_modern</item>
        <item name="android:colorBackground">@color/pos_background</item>
        <item name="colorSurface">@color/pos_surface_dark</item>
        <item name="colorSurfaceVariant">@color/pos_surface</item>
        
        <!-- Text Colors -->
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorOnBackground">@color/pos_text_primary</item>
        <item name="colorOnSurface">@color/pos_text_primary</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status Bar & System -->
        <item name="android:statusBarColor">@color/pos_surface_darker</item>
        <item name="android:navigationBarColor">@color/pos_surface_darker</item>
        <item name="android:forceDarkAllowed">false</item>
        
        <!-- Material Components Theming -->
        <item name="materialButtonStyle">@style/ModernButton</item>
        <item name="materialCardViewStyle">@style/ModernCardView</item>
        <item name="materialAlertDialogTheme">@style/AlertDialogStyle</item>
    </style>

    <!-- Modern Button Style -->
    <style name="ModernButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Modern Card View Style -->
    <style name="ModernCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/pos_border</item>
    </style>

    <!-- ML Preset Button - Enhanced -->
    <style name="MlPresetButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/pos_surface_dark</item>
        <item name="strokeColor">@color/pos_border_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">999dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Section Header Text -->
    <style name="SectionHeaderText">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_text_secondary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Subtitle Text -->
    <style name="SubtitleText">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/pos_text_tertiary</item>
    </style>

    <!-- Enhanced Button Styles -->
    <style name="ButtonGoldStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pos_gold_light</item>
        <item name="android:textColor">@color/pos_background</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">4dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="ButtonBlueStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/pos_gold</item>
        <item name="android:textColor">@color/pos_gold</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="ButtonRedStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pos_error</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">3dp</item>
    </style>

    <!-- Enhanced Text Styles -->
    <style name="TitleLargeStyle">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_gold_light</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TitleMediumStyle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <style name="BodyLargeStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/pos_text_primary</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="BodyMediumStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/pos_text_secondary</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="CurrencyTextStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_success</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Dialog Styles -->
    <style name="AlertDialogStyle" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/DialogBody</item>
        <item name="buttonBarPositiveButtonStyle">@style/ButtonGoldStyle</item>
    </style>

    <style name="DialogTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/pos_gold_light</item>
    </style>

    <style name="DialogBody">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/pos_text_secondary</item>
    </style>

</resources>
