<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="4dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/pos_shadow" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Background -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/pos_surface" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/pos_border_light" />
        </shape>
    </item>
</layer-list>
