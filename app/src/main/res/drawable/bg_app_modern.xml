<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pos_background" />
        </shape>
    </item>

    <!-- Modern Gray Gradient Overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="@color/pos_background_mid"
                android:endColor="@color/pos_background_end"
                android:startColor="@color/pos_background_start"
                android:type="linear" />
        </shape>
    </item>

    <!-- Subtle Pattern Overlay for Modern Look -->
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:centerColor="#00000000"
                android:endColor="@color/pos_overlay_gray"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>