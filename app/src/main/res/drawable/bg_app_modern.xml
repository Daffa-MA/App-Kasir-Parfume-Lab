<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pos_background" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="@color/pos_background_mid"
                android:endColor="@color/pos_background_end"
                android:startColor="@color/pos_background_start" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="@android:color/transparent"
                android:startColor="@color/pos_background_glow_gold" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="225"
                android:endColor="@android:color/transparent"
                android:startColor="@color/pos_background_glow_blue" />
        </shape>
    </item>
</layer-list>