<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_modern"
    android:orientation="vertical"
    android:padding="12dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/pos_surface_dark"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/pos_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checkout &amp; Payment"
                android:textColor="@color/pos_gold_light"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Aura Lab - Selesaikan transaksi dengan cepat"
                android:textColor="@color/pos_text_tertiary"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/pos_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/pos_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="TOTAL TO PAY"
                        android:textColor="@color/pos_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtPaymentTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Rp 0"
                        android:textColor="@color/pos_gold_light"
                        android:textSize="38sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/pos_surface_dark"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/pos_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabCash"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/pos_gold"
                        android:text="Cash"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        app:cornerRadius="999dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabQR"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/pos_surface"
                        android:text="QRIS"
                        android:textAllCaps="false"
                        android:textColor="@color/pos_gold"
                        android:textStyle="bold"
                        app:cornerRadius="999dp"
                        app:strokeColor="@color/pos_border"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/panelCash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/pos_surface_dark"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/pos_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Amount Received"
                            android:textColor="@color/pos_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_search_input"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp"
                                android:textColor="@color/pos_gold"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/edtCash"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@android:color/transparent"
                                android:gravity="end|center_vertical"
                                android:hint="0"
                                android:inputType="number"
                                android:textColor="@color/pos_text_primary"
                                android:textColorHint="@color/pos_text_hint"
                                android:textSize="30sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Numeric Keypad"
                            android:textColor="@color/pos_text_tertiary"
                            android:textSize="11sp" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:columnCount="3">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey1"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="1"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey2"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="2"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey3"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="3"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey4"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="4"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey5"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="5"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey6"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="6"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey7"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="7"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey8"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="8"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey9"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="9"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey0"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="0"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKey00"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="00"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnKeyBackspace"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="DEL"
                                android:textAllCaps="false"
                                android:textColor="@color/pos_gold"
                                app:cornerRadius="10dp" />
                        </GridLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Quick Pay"
                            android:textColor="@color/pos_text_tertiary"
                            android:textSize="11sp" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:columnCount="4">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuickExact"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="EXACT"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuick20k"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="20K"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuick50k"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="50K"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuick100k"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="100K"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuick200k"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="200K"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuick500k"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="3dp"
                                android:text="500K"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuick1000k"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_columnWeight="2"
                                android:layout_margin="3dp"
                                android:text="1000K"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp" />
                        </GridLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/pos_surface"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/pos_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Change to Return"
                            android:textColor="@color/pos_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Rp 0"
                            android:textColor="@color/pos_gold_light"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtShortInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/pos_error"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelQR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QR CODE"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="(Demo)"
                            android:textColor="@color/brand_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Scan untuk bayar"
                    android:textColor="@color/pos_gold"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProcessPayment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/pos_gold"
        android:text="Complete Transaction"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:elevation="4dp" />

</LinearLayout>
