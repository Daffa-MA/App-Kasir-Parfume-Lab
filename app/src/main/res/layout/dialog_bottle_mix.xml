<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtMixBottleInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bottle 30 ml | Rp 7.500"
        android:textColor="@color/pos_blue"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Pilih bibit parfum untuk campuran"
        android:textColor="@color/pos_text_tertiary"
        android:textSize="11sp" />

    <EditText
        android:id="@+id/edtMixSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@android:drawable/edit_text"
        android:hint="Search bibit parfum"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textColor="@color/pos_text_primary"
        android:textColorHint="@color/pos_text_hint" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMixPerfume"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="@color/pos_surface"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/pos_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtMixTotalMl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total bibit: 0 ml"
                android:textColor="@color/pos_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMixAlcoholInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Alkohol: 0 ml (aktif jika > 100 ml)"
                android:textColor="@color/pos_text_tertiary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtMixAlcoholPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Harga alkohol: Rp 0"
                android:textColor="@color/pos_blue"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMixSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Perfume Rp 0 + Bottle Rp 0"
                android:textColor="@color/pos_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtMixTotalPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Total: Rp 0"
                android:textColor="@color/pos_gold"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddMixToCart"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/pos_gold"
        android:text="Tambah Mix ke Cart"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</LinearLayout>
