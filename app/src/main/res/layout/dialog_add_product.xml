<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintTextColor="@color/pos_text_tertiary">

        <EditText
            android:id="@+id/edtProductId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product ID (e.g., P001)"
            android:inputType="text"
            android:textColor="@color/pos_text_primary"
            android:textColorHint="@color/pos_text_tertiary"
            android:background="@drawable/background_edittext" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintTextColor="@color/pos_text_tertiary">

        <EditText
            android:id="@+id/edtProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product Name"
            android:inputType="text"
            android:textColor="@color/pos_text_primary"
            android:textColorHint="@color/pos_text_tertiary"
            android:background="@drawable/background_edittext" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/txtLabel1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price Per Ml (Rp)"
            android:textColor="@color/pos_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintTextColor="@color/pos_text_tertiary">

            <EditText
                android:id="@+id/edtProductValue1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Value"
                android:inputType="numberDecimal"
                android:textColor="@color/pos_text_primary"
                android:textColorHint="@color/pos_text_tertiary"
                android:background="@drawable/background_edittext" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/txtLabel2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stock (ml)"
            android:textColor="@color/pos_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintTextColor="@color/pos_text_tertiary">

            <EditText
                android:id="@+id/edtProductValue2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Value"
                android:inputType="numberDecimal"
                android:textColor="@color/pos_text_primary"
                android:textColorHint="@color/pos_text_tertiary"
                android:background="@drawable/background_edittext" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtLabel3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stock (pcs)"
            android:textColor="@color/pos_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintTextColor="@color/pos_text_tertiary">

            <EditText
                android:id="@+id/edtProductValue3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Value"
                android:inputType="number"
                android:textColor="@color/pos_text_primary"
                android:textColorHint="@color/pos_text_tertiary"
                android:background="@drawable/background_edittext"
                android:visibility="gone" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</LinearLayout>
