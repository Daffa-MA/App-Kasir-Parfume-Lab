<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_modern">

    <!-- Header -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardBackgroundColor="@color/pos_surface"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPrinterBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="24sp"
                android:textColor="@color/pos_gold"
                android:background="@android:color/transparent"
                android:padding="0dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pengaturan Printer"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/pos_gold"
                android:paddingStart="16dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Printer Status Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/pos_surface"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/pos_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status Printer"
                        android:textColor="@color/pos_gold"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/txtPrinterName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Printer: Belum dikonfigurasi"
                        android:textColor="@color/pos_text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnScanPrinters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pindai Printer"
                        android:textColor="@color/pos_background"
                        android:background="@drawable/btn_gold_gradient"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Connection Settings Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/pos_surface"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/pos_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pengaturan Koneksi"
                        android:textColor="@color/pos_gold"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tipe Koneksi"
                        android:textColor="@color/pos_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerConnectionType"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/background_edittext" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lebar Kertas"
                        android:textColor="@color/pos_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerPaperWidth"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_edittext" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Printer Settings Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/pos_surface"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/pos_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Opsi Cetak"
                        android:textColor="@color/pos_gold"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Auto Print -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cetak Otomatis"
                            android:textColor="@color/pos_text_primary"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switchAutoPrint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Open Drawer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Buka Drawer Otomatis"
                            android:textColor="@color/pos_text_primary"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switchOpenDrawer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Print Preview -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Preview Sebelum Cetak"
                            android:textColor="@color/pos_text_primary"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switchPrintPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnTestPrint"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Cetak Test"
                    android:textColor="@color/pos_background"
                    android:background="@drawable/btn_gold_gradient"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnSaveSettings"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Simpan Pengaturan"
                    android:textColor="@color/pos_background"
                    android:textColorHint="@color/pos_text_hint"
                    android:background="@drawable/btn_gold_gradient" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
